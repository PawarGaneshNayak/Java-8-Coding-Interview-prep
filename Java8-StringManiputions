	private static String getReversed(String word) {
//		return word.chars()
//				.mapToObj(c -> (char)c)
//				.map(String::valueOf)
//				.reduce((a,b) -> b+a ).get();
		
		 return IntStream.range(0, word.length())
			.mapToObj(i -> word.charAt(word.length() -1 -i))
			.map(String::valueOf)
			.collect(Collectors.joining());

	}
	
	private static boolean checkPalidrome(String s) {
		return IntStream.range(0, s.length()/2)
			.allMatch(i -> s.charAt(i) == s.charAt(s.length() -1 - i));
	}

